{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "kowork",
	"version": "0.1.0",
	"identifier": "com.pedro.kowork",
	"build": {
		"devUrl": "http://localhost:4178",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "Kowork",
				"width": 1080,
				"height": 750,
				"minWidth": 512,
				"minHeight": 500,
				"center": true,
				"decorations": false,
				"resizable": true,
				"visible": false,
				"skipTaskbar": true,
				"alwaysOnTop": false,
				"transparent": false
			}
		],
		"security": {
			"csp": null,
			"capabilities": [
				{
					"identifier": "main",
					"windows": ["main"],
					"permissions": ["core:default", "core:window:allow-start-dragging"]
				}
			]
		}
	},
	"bundle": {
		"active": true,
		"targets": ["deb", "rpm"],
		"resources": ["bin/kowork-backend", "../dist"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
