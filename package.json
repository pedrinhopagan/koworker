{
	"name": "koworker",
	"version": "0.1.0",
	"private": true,
	"description": "Koworker - ERP full-stack brasileiro com projetos e tarefas para AI Coding Agents",
	"homepage": "https://github.com/pedrinhopagan/koworker",
	"license": "UNLICENSED",
	"author": "pedrinhopagan",
	"repository": {
		"type": "git",
		"url": "https://github.com/pedrinhopagan/koworker.git"
	},
	"bin": {
		"kowork": "./src/cli/index.ts"
	},
	"type": "module",
	"scripts": {
		"setup": "bun run scripts/setup.ts",
		"dev": "concurrently -k 'tsr watch' 'bun --watch src/server.ts' 'cargo tauri dev'",
		"dev:web": "concurrently 'tsr watch' 'bun --watch src/server.ts'",
		"build:web": "bun run scripts/desktop/build-web.ts",
		"build:backend": "bun run scripts/desktop/build-backend.ts",
		"desktop:prepare": "bun run build:web && bun run build:backend",
		"desktop:build": "bun run desktop:prepare && cargo tauri build",
		"desktop:update": "bash ./scripts/desktop/update-and-build.sh",
		"deploy": "bun run scripts/desktop/deploy.ts",
		"tauri": "cargo tauri",
		"tauri:dev": "cargo tauri dev",
		"tauri:build": "cargo tauri build",
		"cli": "bun run src/cli/index.ts",
		"oxlint": "oxlint src scripts --ignore-pattern='*.gen.ts'",
		"seed": "bun run scripts/seed.ts"
	},
	"dependencies": {
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/language": "^6.12.3",
		"@codemirror/language-data": "^6.5.2",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.43.0",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/modifiers": "^9.0.0",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@hookform/resolvers": "^5.2.2",
		"@lezer/highlight": "^1.2.3",
		"@lobomfz/db": "^0.1.0",
		"@orpc/client": "^1.13.4",
		"@orpc/experimental-publisher": "^1.13.4",
		"@orpc/server": "^1.13.4",
		"@orpc/tanstack-query": "^1.13.4",
		"@radix-ui/react-accordion": "^1.2.12",
		"@radix-ui/react-checkbox": "^1.3.3",
		"@radix-ui/react-context-menu": "^2.2.16",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-switch": "^1.2.6",
		"@tanstack/react-query": "^5.90.20",
		"@tanstack/react-router": "^1.157.10",
		"@tauri-apps/api": "^2.9.1",
		"@uiw/react-codemirror": "^4.25.10",
		"arktype": "^2.1.29",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dayjs": "^1.11.19",
		"dotenv": "^17.2.3",
		"jose": "^6.1.3",
		"kysely": "^0.28.10",
		"lucide-react": "^0.563.0",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"react-hook-form": "^7.71.1",
		"react-markdown": "^10.1.0",
		"remark-gfm": "^4.0.1",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"yaml": "^2.8.2",
		"zod": "^4.3.6",
		"zustand": "^5.0.10"
	},
	"devDependencies": {
		"@tailwindcss/cli": "^4.1.18",
		"@tanstack/router-cli": "^1.157.10",
		"@types/bun": "^1.3.6",
		"@types/node": "^25.0.10",
		"@types/react": "^19.2.9",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260124.1",
		"bun-plugin-tailwind": "^0.1.2",
		"concurrently": "^9.2.1",
		"knip": "^5.82.1",
		"lefthook": "^2.0.15",
		"oxfmt": "^0.26.0",
		"oxlint": "^1.41.0",
		"typescript": "^5.9.3"
	}
}
